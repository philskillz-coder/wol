# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# OAuth2 - Authentik
AUTHENTIK_AUTHORIZATION_URL=https://your-authentik-instance/application/o/authorize/
AUTHENTIK_TOKEN_URL=https://your-authentik-instance/application/o/token/
AUTHENTIK_USERINFO_URL=https://your-authentik-instance/application/o/userinfo/
AUTHENTIK_CLIENT_ID=your_authentik_client_id
AUTHENTIK_CLIENT_SECRET=your_authentik_client_secret
AUTHENTIK_CALLBACK_URL=http://localhost:3000/auth/authentik/callback

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-change-in-production
