// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  oauthId   String     @unique
  email     String     @unique
  name      String?
  provider  String     // 'github' | 'google'
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  devices   Device[]
  logs      Log[]
  apiTokens ApiToken[]

  @@map("users")
}

model Device {
  id              String           @id @default(uuid())
  name            String
  macAddress      String
  ipAddress       String?
  mode            String           @default("PASSIVE") // DeviceMode: ACTIVE | PASSIVE
  status          String           @default("UNKNOWN") // DeviceStatus: ONLINE | OFFLINE | STANDBY | UNKNOWN
  lastSeen        DateTime?
  secret          String // Secret für Client-Authentifizierung
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            Log[]
  apiTokenDevices ApiTokenDevice[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("devices")
}

model ApiToken {
  id             String           @id @default(uuid())
  name           String
  token          String           @unique // Hashed token
  lastUsedAt     DateTime?
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowedDevices ApiTokenDevice[]
  createdAt      DateTime         @default(now())
  expiresAt      DateTime?

  @@map("api_tokens")
}

// When empty: API token may access all of the user's devices. When non-empty: only listed devices.
model ApiTokenDevice {
  apiTokenId String
  deviceId   String
  apiToken   ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([apiTokenId, deviceId])
  @@map("api_token_devices")
}

model Log {
  id        String   @id @default(uuid())
  type      String   // LogType: DEVICE_CREATED | DEVICE_UPDATED | DEVICE_DELETED | WAKE_SENT | SHUTDOWN_SENT | STATUS_CHANGED | CLIENT_CONNECTED | CLIENT_DISCONNECTED | ERROR | INFO
  message   String
  deviceId  String?
  device    Device?  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("logs")
}
