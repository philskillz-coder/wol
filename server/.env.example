# Copy to `server/.env` and adjust. Used by:
#   - Docker Compose (project dir = folder containing this file + docker-compose.yml)
#   - `npm run dev` (backend + frontend load paths relative to server/backend and server/frontend)
#
# Required (no silent fallback defaults):
# - Missing/invalid ports or URLs abort startup/build.
# - URL ports must match the corresponding *_PORT values.

DOMAIN=localhost
BACKEND_PORT=6010
FRONTEND_PORT=6020

NODE_ENV=development
BACKEND_URL=http://localhost:6010
FRONTEND_URL=http://localhost:6020

# SQLite: relative paths resolve from the process cwd (backend: /app in Docker, server/backend locally).
DATABASE_URL=file:./dev.db

# OAuth2 (Authentik) — replace with your provider values
AUTHENTIK_AUTHORIZATION_URL=
AUTHENTIK_TOKEN_URL=
AUTHENTIK_USERINFO_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_CALLBACK_URL=http://localhost:6010/auth/authentik/callback

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

SESSION_SECRET=change-me

# Optional overrides for active-agent download config (defaults follow BACKEND_URL)
# SERVER_URL=http://localhost:6010
# WS_URL=ws://localhost:6010/ws
